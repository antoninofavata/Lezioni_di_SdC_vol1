\@writefile{lof}{\contentsline {figure}{\numberline {6.7}{\ignorespaces Composizione di $n$ rotazioni infinitesime nel piano. (a)~Vista tridimensionale: le rotazioni sono vettori assiali $\bm  {\upvartheta }_i$ ortogonali al piano $\pi $, che si sommano nella risultante $\bm  {\upvartheta }=\sum _i\bm  {\upvartheta }_i$ in $C$. (b)~Vista nel piano $(x,y)$: ampiezze $\vartheta _i$ come archi orientati (positivi se antiorari) e centro risultante $C$ nel baricentro dei $C_i$. Il centro $C$ è individuato da $\overrightarrow {OC}=\bigl ( \sum _i\vartheta _i\nobreak  \hskip 0.07em\overrightarrow {OC_i}\bigr )/\vartheta $ o, in forma equivalente, da $\sum _i\vartheta _i\nobreak  \hskip 0.07em \overrightarrow {CC_i}=\mathbf  {0}$ (frecce grigie in~(b)).}}{106}{figure.caption.49}\protected@file@percent }
\newlabel{fig:composizione_rot}{{6.7}{106}{Composizione di $n$ rotazioni infinitesime nel piano. (a)~Vista tridimensionale: le rotazioni sono vettori assiali $\bm {\upvartheta }_i$ ortogonali al piano $\pi $, che si sommano nella risultante $\bm {\upvartheta }=\protect \sum _i\bm {\upvartheta }_i$ in $C$. (b)~Vista nel piano $(x,y)$: ampiezze $\vartheta _i$ come archi orientati (positivi se antiorari) e centro risultante $C$ nel baricentro dei $C_i$. Il centro $C$ è individuato da $\protect \overrightarrow {OC}=\protect \bigl ( \protect \sum _i\vartheta _i\,\protect \overrightarrow {OC_i}\protect \bigr )/\vartheta $ o, in forma equivalente, da $\protect \sum _i\vartheta _i\, \protect \overrightarrow {CC_i}=\zerovb $ (frecce grigie in~(b))}{figure.caption.49}{}}
\@writefile{toc}{\contentsline {paragraph}{\numberline {6.6.3.1}Caso di due rotazioni.}{107}{paragraph.6.6.3.0.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6.8}{\ignorespaces Composizione di due rotazioni infinitesime nel piano come diagramma degli spostamenti trasversali alla congiungente $C_1C_2$: la retta spessa è $v(x)=\vartheta _1\nobreak  \hskip 0.07em(x-x_{C_1})+\vartheta _2\nobreak  \hskip 0.07em(x-x_{C_2})$ e il centro risultante $C$ è il suo zero, con $\vartheta \nobreak  \hskip 0.07em\overline  {CC_1}=|\vartheta _2|\nobreak  \hskip 0.07em\overline  {C_1C_2}$. (a)~Concordi: $C$ interno a $C_1C_2$. (b)~Discordi ($|\vartheta _2|>\vartheta _1$): $C$ esterno, oltre $C_2$.}}{107}{figure.caption.50}\protected@file@percent }
\newlabel{fig:composizione_2_rot}{{6.8}{107}{Composizione di due rotazioni infinitesime nel piano come diagramma degli spostamenti trasversali alla congiungente $C_1C_2$: la retta spessa è $v(x)=\vartheta _1\,(x-x_{C_1})+\vartheta _2\,(x-x_{C_2})$ e il centro risultante $C$ è il suo zero, con $\vartheta \,\overline {CC_1}=|\vartheta _2|\,\overline {C_1C_2}$. (a)~Concordi: $C$ interno a $C_1C_2$. (b)~Discordi ($|\vartheta _2|>\vartheta _1$): $C$ esterno, oltre $C_2$}{figure.caption.50}{}}
\newlabel{eq:comp_due_rot}{{6.50}{108}{Caso di due rotazioni}{equation.6.6.50}{}}
