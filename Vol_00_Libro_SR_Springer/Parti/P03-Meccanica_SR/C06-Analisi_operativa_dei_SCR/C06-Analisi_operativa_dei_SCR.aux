\@writefile{lof}{\contentsline {figure}{\numberline {11.3}{\ignorespaces Soluzione grafica per i cedimenti interni in $D$. \emph  {(a)}~cedimento $s_3$ (orizzontale): tre centri distinti, $C_1\equiv A$, $C_2\equiv B$ fissati dai vincoli a cedimento nullo, $C_{12}$ punto medio di $AB$. \emph  {(b)}~cedimento $s_4$ (verticale): caso degenere, $C_{12}$ punto improprio della direzione orizzontale, e i due semiarchi ruotano della stessa quantità attorno ai rispettivi centri $C_1\equiv A$ e $C_2\equiv B$.}}{213}{figure.caption.92}\protected@file@percent }
\newlabel{fig:arco_cedimenti_interni}{{11.3}{213}{Soluzione grafica per i cedimenti interni in $D$. \emph {(a)}~cedimento $s_3$ (orizzontale): tre centri distinti, $C_1\equiv A$, $C_2\equiv B$ fissati dai vincoli a cedimento nullo, $C_{12}$ punto medio di $AB$. \emph {(b)}~cedimento $s_4$ (verticale): caso degenere, $C_{12}$ punto improprio della direzione orizzontale, e i due semiarchi ruotano della stessa quantità attorno ai rispettivi centri $C_1\equiv A$ e $C_2\equiv B$}{figure.caption.92}{}}
