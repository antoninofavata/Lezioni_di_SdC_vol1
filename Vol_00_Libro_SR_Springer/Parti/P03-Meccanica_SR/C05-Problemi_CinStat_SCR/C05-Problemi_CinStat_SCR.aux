\newlabel{eq:rango}{{10.26}{192}{La formula fondamentale di classificazione}{equation.10.4.26}{}}
\newlabel{eq:labilita}{{10.27}{192}{La formula fondamentale di classificazione}{equation.10.4.27}{}}
