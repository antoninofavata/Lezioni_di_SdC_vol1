\@writefile{lot}{\contentsline {table}{\numberline {10.2}{\ignorespaces Sintesi dei quattro sottospazi fondamentali di $\bm  {A}$ e del loro significato meccanico. I due sottospazi di $\mathbb  {R}^{n}$ sono ortogonali ($\mathcal  {N}(\bm  {A}) \perp \mathcal  {I}(\bm  {A}^{\top })$); idem per i due di $\mathbb  {R}^{m}$ ($\mathcal  {N}(\bm  {A}^\top ) \perp \mathcal  {I}(\bm  {A})$).}}{192}{table.caption.82}\protected@file@percent }
\newlabel{tab:quattro_sottospazi}{{10.2}{192}{Sintesi dei quattro sottospazi fondamentali di $\bm {A}$ e del loro significato meccanico. I due sottospazi di $\mathbb {R}^{n}$ sono ortogonali ($\Nc (\bm {A}) \perp \Ic (\bm {A}^{\top })$); idem per i due di $\mathbb {R}^{m}$ ($\Nc (\bm {A}^\top ) \perp \Ic (\bm {A})$)}{table.caption.82}{}}
