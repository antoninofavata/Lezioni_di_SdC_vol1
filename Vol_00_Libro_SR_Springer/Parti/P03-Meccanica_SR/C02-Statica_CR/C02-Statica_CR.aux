\@writefile{toc}{\contentsline {subsection}{\numberline {7.6.2}Operazioni elementari di equivalenza}{123}{subsection.7.6.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{\numberline {7.6.2.1}Traslazione lungo la linea d'azione.}{123}{paragraph.7.6.2.0.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{\numberline {7.6.2.2}Composizione di forze concorrenti.}{123}{paragraph.7.6.2.0.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7.5}{\ignorespaces Operazioni elementari di equivalenza (I). \textbf  {\textit  {(a)}}~Traslazione della forza $\mathbf  {f}_k$ lungo la propria linea d'azione da $P_k$ a $P_k'$: risultante e momento risultante restano invariati. \textbf  {\textit  {(b)}}~Composizione di due forze concorrenti in $P$: il sistema è equivalente alla risultante $\mathbf  {f}_1+\mathbf  {f}_2$ applicata in $P$. \textbf  {\textit  {(c)}}~Decomposizione della forza $\mathbf  {f}$ applicata in $P$ nelle componenti $\mathbf  {f}_1$ e $\mathbf  {f}_2$ secondo due direzioni indipendenti: operazione inversa alla composizione.}}{124}{figure.caption.58}\protected@file@percent }
\newlabel{fig:operazioni_elementari_1}{{7.5}{124}{Operazioni elementari di equivalenza (I). \textbf {\textit {(a)}}~Traslazione della forza $\fb _k$ lungo la propria linea d'azione da $P_k$ a $P_k'$: risultante e momento risultante restano invariati. \textbf {\textit {(b)}}~Composizione di due forze concorrenti in $P$: il sistema è equivalente alla risultante $\fb _1+\fb _2$ applicata in $P$. \textbf {\textit {(c)}}~Decomposizione della forza $\fb $ applicata in $P$ nelle componenti $\fb _1$ e $\fb _2$ secondo due direzioni indipendenti: operazione inversa alla composizione}{figure.caption.58}{}}
\@writefile{toc}{\contentsline {paragraph}{\numberline {7.6.2.3}Aggiunta o rimozione di un sistema equilibrato.}{124}{paragraph.7.6.2.0.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7.6}{\ignorespaces Trasporto di una forza in un punto non appartenente alla linea d'azione. \textbf  {\textit  {(a)}}~Sistema originale: forza $\mathbf  {f}$ applicata in $P$. \textbf  {\textit  {(b)}}~Aggiunta in $Q$ della coppia equilibrata $(\mathbf  {f},\nobreak  \hskip 0.07em-\mathbf  {f})$: la forza $(P,\nobreak  \hskip 0.07em\mathbf  {f})$ e $(Q,\nobreak  \hskip 0.07em-\mathbf  {f})$ formano una coppia di momento $\bm  {\upmu } = \overrightarrow {QP}\times \mathbf  {f}$, con braccio $b$. \textbf  {\textit  {(c)}}~Sistema equivalente: forza $\mathbf  {f}$ applicata in $Q$ più la coppia correttiva oraria di intensità $\mu (Q) = |\mathbf  {f}|\nobreak  \hskip 0.07emb$.}}{125}{figure.caption.59}\protected@file@percent }
\newlabel{fig:trasporto_forza}{{7.6}{125}{Trasporto di una forza in un punto non appartenente alla linea d'azione. \textbf {\textit {(a)}}~Sistema originale: forza $\fb $ applicata in $P$. \textbf {\textit {(b)}}~Aggiunta in $Q$ della coppia equilibrata $(\fb ,\,-\fb )$: la forza $(P,\,\fb )$ e $(Q,\,-\fb )$ formano una coppia di momento $\bm {\upmu } = \protect \overrightarrow {QP}\times \fb $, con braccio $b$. \textbf {\textit {(c)}}~Sistema equivalente: forza $\fb $ applicata in $Q$ più la coppia correttiva oraria di intensità $\mu (Q) = |\fb |\,b$}{figure.caption.59}{}}
