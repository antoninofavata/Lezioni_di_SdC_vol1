\@writefile{lof}{\contentsline {figure}{\numberline {7.1}{\ignorespaces (a)~Momento $\bm  {\upmu }_k(O)$ rispetto al polo $O$ della forza $(P_k,\mathbf  {f}_k)$, definito come $\bm  {\upmu }^O_k = \overrightarrow {OP_k}\times \mathbf  {f}_k$. (b)~Componenti cartesiane $x_k,y_k,z_k$ del vettore posizione $\overrightarrow {OP_k}$ e componenti $X_k,Y_k,Z_k$ della forza $\mathbf  {f}_k$.}}{117}{figure.caption.54}\protected@file@percent }
\newlabel{fig:momento_forza}{{7.1}{117}{(a)~Momento $\bm {\upmu }_k(O)$ rispetto al polo $O$ della forza $(P_k,\fb _k)$, definito come $\bm {\upmu }^O_k = \protect \overrightarrow {OP_k}\times \fb _k$. (b)~Componenti cartesiane $x_k,y_k,z_k$ del vettore posizione $\protect \overrightarrow {OP_k}$ e componenti $X_k,Y_k,Z_k$ della forza $\fb _k$}{figure.caption.54}{}}
\newlabel{eq:coppia}{{7.6}{117}{Coppia di forze}{equation.7.2.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7.2}{\ignorespaces Momento della coppia generata dalle forze $\mathbf  {f}_1$ e $\mathbf  {f}_2=-\mathbf  {f}_1$ applicate in $P_1$ e $P_2$. Il momento $\bm  {\upmu }=\overrightarrow {P_2P_1}\times \mathbf  {f}_1$ è perpendicolare al piano delle forze, con modulo $|\mathbf  {f}_1|\nobreak  \hskip 0.07emb$ e braccio $b=|\overrightarrow {P_2P_1}|\sin \alpha $, ed è indipendente dal polo $O$.}}{117}{figure.caption.55}\protected@file@percent }
\newlabel{fig:coppia}{{7.2}{117}{Momento della coppia generata dalle forze $\fb _1$ e $\fb _2=-\fb _1$ applicate in $P_1$ e $P_2$. Il momento $\bm {\upmu }=\protect \overrightarrow {P_2P_1}\times \fb _1$ è perpendicolare al piano delle forze, con modulo $|\fb _1|\,b$ e braccio $b=|\protect \overrightarrow {P_2P_1}|\sin \alpha $, ed è indipendente dal polo $O$}{figure.caption.55}{}}
\newlabel{eq:riduzione_generalizzata}{{7.7}{117}{Coppia di forze}{equation.7.2.7}{}}
