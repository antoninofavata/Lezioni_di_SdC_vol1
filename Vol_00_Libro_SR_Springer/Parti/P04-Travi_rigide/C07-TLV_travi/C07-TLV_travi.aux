\@writefile{lof}{\contentsline {figure}{\numberline {20.5}{\ignorespaces Trave di Gerber: applicazione del TFV per il calcolo dello spostamento $\eta _H$ in mezzeria della travata portata $EF$, sotto cedimento $\bar  s_A$ in $A$ e distorsioni $\bar  \varrho _v$, $\bar  \varrho _\vartheta $ in $G$.}}{517}{figure.caption.238}\protected@file@percent }
\newlabel{fig:TFV_gerber}{{20.5}{517}{Trave di Gerber: applicazione del TFV per il calcolo dello spostamento $\eta _H$ in mezzeria della travata portata $EF$, sotto cedimento $\bar s_A$ in $A$ e distorsioni $\bar \varrho _v$, $\bar \varrho _\vartheta $ in $G$}{figure.caption.238}{}}
\newlabel{subsec:TFV_reticolare}{{20.7}{518}{Calcolo di uno spostamento nodale di una travatura reticolare mediante TFV}{esempioinner.20.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20.6}{\ignorespaces Teorema delle forze virtuali applicato alla travatura reticolare del Paragrafo~\ref {subsec:LI_reticolare}. A sinistra: sistema reale, con distorsioni longitudinali $\bar  \varrho ^{(4)}$, $\bar  \varrho ^{(2)}$, $\bar  \varrho ^{(8)}$ assegnate sulle aste~$4$, $2$, $8$ (due di allungamento, una di accorciamento) e cedimento verticale $\bar  s_1$ del nodo~$1$. A destra: sistema virtuale, con forza unitaria verticale $F^{*}=1$ applicata nel nodo~$6$, reazioni virtuali $Y_1^{*}=Y_4^{*} =\tfrac  {1}{2}$ ai vincoli e sforzi normali $N^{*(2)}$, $N^{*(4)}$, $N^{*(8)}$ nelle tre aste recise dalla sezione di Ritter. I poli di Ritter $R_2\equiv 6$ e $R_4\equiv 2$ sono evidenziati con cerchio concentrico; il polo $R_8$ è all'infinito in direzione orizzontale, come duale statico del centro relativo $C_{L,R}$ all'infinito del pannello~(d) della figura del Paragrafo~\ref {subsec:LI_reticolare}.}}{519}{figure.caption.239}\protected@file@percent }
\newlabel{fig:TFV_reticolare}{{20.6}{519}{Teorema delle forze virtuali applicato alla travatura reticolare del \PARref {subsec:LI_reticolare}. A sinistra: sistema reale, con distorsioni longitudinali $\bar \varrho ^{(4)}$, $\bar \varrho ^{(2)}$, $\bar \varrho ^{(8)}$ assegnate sulle aste~$4$, $2$, $8$ (due di allungamento, una di accorciamento) e cedimento verticale $\bar s_1$ del nodo~$1$. A destra: sistema virtuale, con forza unitaria verticale $F^{*}=1$ applicata nel nodo~$6$, reazioni virtuali $Y_1^{*}=Y_4^{*} =\tfrac {1}{2}$ ai vincoli e sforzi normali $N^{*(2)}$, $N^{*(4)}$, $N^{*(8)}$ nelle tre aste recise dalla sezione di Ritter. I poli di Ritter $R_2\equiv 6$ e $R_4\equiv 2$ sono evidenziati con cerchio concentrico; il polo $R_8$ è all'infinito in direzione orizzontale, come duale statico del centro relativo $C_{L,R}$ all'infinito del pannello~(d) della figura del \PARref {subsec:LI_reticolare}}{figure.caption.239}{}}
