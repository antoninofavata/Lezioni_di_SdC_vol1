\@writefile{lof}{\contentsline {figure}{\numberline {18.25}{\ignorespaces $(a)$~Stato di sollecitazione: tratto spesso le aste compresse (puntoni $AD$, $DE$, $BE$, $EC$), tratto sottile le aste tese (tiranti $AB$, $BC$, $DB$). $(b)$~Sezione di Ritter sul pannello centrale: il taglio attraversa $AB$, $DB$ ed $DE$. I poli dei due correnti coincidono con nodi della travatura, $P_{DE}\equiv B$ e $P_{AB}\equiv D$; poiché i correnti $AB$ e $DE$ sono paralleli, il polo della diagonale $DB$ è all'infinito e $N_{DB}$ si ricava dall'equilibrio alla traslazione verticale.}}{518}{figure.caption.205}\protected@file@percent }
