\@writefile{lof}{\contentsline {figure}{\numberline {1.9}{\ignorespaces Allineamento dei centri di rotazione $C_i$, $C_j$ e $C_{ij}$ con $|\vartheta _j| = 2|\vartheta _i|$. \textbf  {\textit  {(a)}}~Rotazioni discordi ($\vartheta _i > 0$, $\vartheta _j = -2\vartheta _i$): $C_{ij}$ cade all'interno del segmento $C_iC_j$, a distanza $\tfrac  {2}{3}|C_iC_j|$ da $C_i$. \textbf  {\textit  {(b)}}~Rotazioni concordi ($\vartheta _i > 0$, $\vartheta _j = 2\vartheta _i$): $C_{ij}$ cade all'esterno, oltre $C_j$, a distanza $2|C_iC_j|$ da $C_i$.}}{28}{figure.caption.11}\protected@file@percent }
\newlabel{fig:allineamento_CR}{{1.9}{28}{Allineamento dei centri di rotazione $C_i$, $C_j$ e $C_{ij}$ con $|\vartheta _j| = 2|\vartheta _i|$. \textbf {\textit {(a)}}~Rotazioni discordi ($\vartheta _i > 0$, $\vartheta _j = -2\vartheta _i$): $C_{ij}$ cade all'interno del segmento $C_iC_j$, a distanza $\tfrac {2}{3}|C_iC_j|$ da $C_i$. \textbf {\textit {(b)}}~Rotazioni concordi ($\vartheta _i > 0$, $\vartheta _j = 2\vartheta _i$): $C_{ij}$ cade all'esterno, oltre $C_j$, a distanza $2|C_iC_j|$ da $C_i$}{figure.caption.11}{}}
\newlabel{eq:rot_da_centri}{{1.55}{29}{}{equation.1.7.55}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.10}{\ignorespaces Cinematica grafica: determinazione di $\vartheta _j$ dalla posizione dei centri e da $\vartheta _i$. La retta $C_iC_{ij}C_j$ ruota di $\vartheta _i$ attorno a $C_i$; lo spostamento verticale di $C_{ij}$ è proporzionale alla sua distanza da $C_i$. La retta grigia da $C_j$ alla posizione ruotata di $C_{ij}$ evidenzia per similitudine il rapporto $|\vartheta _j|/|\vartheta _i| = |C_jC_{ij}|/|C_iC_{ij}|$.}}{29}{figure.caption.12}\protected@file@percent }
\newlabel{fig:cinematica_grafica}{{1.10}{29}{Cinematica grafica: determinazione di $\vartheta _j$ dalla posizione dei centri e da $\vartheta _i$. La retta $C_iC_{ij}C_j$ ruota di $\vartheta _i$ attorno a $C_i$; lo spostamento verticale di $C_{ij}$ è proporzionale alla sua distanza da $C_i$. La retta grigia da $C_j$ alla posizione ruotata di $C_{ij}$ evidenzia per similitudine il rapporto $|\vartheta _j|/|\vartheta _i| = |C_jC_{ij}|/|C_iC_{ij}|$}{figure.caption.12}{}}
