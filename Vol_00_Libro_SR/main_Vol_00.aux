\@writefile{lof}{\contentsline {figure}{\numberline {1.11}{\ignorespaces Cinematica grafica: determinazione di $\vartheta _j$ dalla posizione dei centri e da $\vartheta _i$. La retta $C_iC_{ij}C_j$ ruota di $\vartheta _i$ attorno a $C_i$; lo spostamento verticale di $C_{ij}$ è proporzionale alla sua distanza da $C_i$. La retta grigia da $C_j$ alla posizione ruotata di $C_{ij}$ evidenzia per similitudine il rapporto $|\vartheta _j|/|\vartheta _i| = |C_jC_{ij}|/|C_iC_{ij}|$.}}{30}{figure.caption.14}\protected@file@percent }
\newlabel{fig:cinematica_grafica}{{1.11}{30}{Cinematica grafica: determinazione di $\vartheta _j$ dalla posizione dei centri e da $\vartheta _i$. La retta $C_iC_{ij}C_j$ ruota di $\vartheta _i$ attorno a $C_i$; lo spostamento verticale di $C_{ij}$ è proporzionale alla sua distanza da $C_i$. La retta grigia da $C_j$ alla posizione ruotata di $C_{ij}$ evidenzia per similitudine il rapporto $|\vartheta _j|/|\vartheta _i| = |C_jC_{ij}|/|C_iC_{ij}|$}{figure.caption.14}{}}
