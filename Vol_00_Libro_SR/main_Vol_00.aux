\@writefile{lof}{\contentsline {figure}{\numberline {18.27}{\ignorespaces $(a)$~Stato di sollecitazione: tratto spesso le aste compresse (puntoni $AE$, $CE$, $DE$), tratto sottile le aste tese (tiranti $AB$, $BC$, $CD$, $BE$). $(b)$~Sezione di Ritter che isola la punta caricata $\{C,D\}$ tagliando $BC$, $CE$ ed $DE$. I tre poli coincidono con nodi della travatura: $P_{BC}\equiv E$, $P_{CE}\equiv D$, $P_{DE}\equiv C$.}}{521}{figure.caption.207}\protected@file@percent }
