\@writefile{lof}{\contentsline {figure}{\numberline {17.20}{\ignorespaces Ponte a stampella: schema strutturale e tre scenari di carico. La travata $CDEFG$ (quota $\ell /4$) poggia sulle quattro bielle $AC$, $AD$, $BF$, $BG$ incernierate al suolo in $A$ e $B$; le cerniere interne sono in $C,D,E,F,G$, con $E$ cerniera di chiave. I tre scenari, disegnati su quote crescenti per chiarezza, sono: \emph  {(a)}~carico $p$ su tutta la travata $CDEFG$; \emph  {(b)}~carico $p$ sul tratto centrale $DEF$; \emph  {(c)}~carico $p$ su $CD$ ed $EF$ (asimmetrico). Le linee tratteggiate riportano l'estensione dei carichi (b) e (c) sulla travata.}}{448}{figure.caption.173}\protected@file@percent }
\newlabel{fig:stampella_schema}{{17.20}{448}{Ponte a stampella: schema strutturale e tre scenari di carico. La travata $CDEFG$ (quota $\ell /4$) poggia sulle quattro bielle $AC$, $AD$, $BF$, $BG$ incernierate al suolo in $A$ e $B$; le cerniere interne sono in $C,D,E,F,G$, con $E$ cerniera di chiave. I tre scenari, disegnati su quote crescenti per chiarezza, sono: \emph {(a)}~carico $p$ su tutta la travata $CDEFG$; \emph {(b)}~carico $p$ sul tratto centrale $DEF$; \emph {(c)}~carico $p$ su $CD$ ed $EF$ (asimmetrico). Le linee tratteggiate riportano l'estensione dei carichi (b) e (c) sulla travata}{figure.caption.173}{}}
\@writefile{toc}{\contentsline {paragraph}{1.~Classificazione statico-cinematica.}{448}{figure.caption.173}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{2.~Strategia risolutiva (comune ai tre scenari).}{449}{figure.caption.173}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {17.21}{\ignorespaces Caso (a), carico $p$ su tutta la travata $CDEFG$ --- (a) schema e reazioni; (b) sforzo normale $N$ sulle travi (le bielle, scariche, portano $N$ uniforme: $N_{AC}=N_{BG}=-\tfrac  {5\sqrt  5}{12}$, $N_{AD}=N_{BF}=-\tfrac  {25\sqrt  {17}}{12}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$; i diagrammi $N$ e $M$ simmetrici rispetto a $E$, quello di $T$ è emisimmetrico.}}{452}{figure.caption.174}\protected@file@percent }
\newlabel{fig:stampella_NTM_a}{{17.21}{452}{Caso (a), carico $p$ su tutta la travata $CDEFG$ --- (a) schema e reazioni; (b) sforzo normale $N$ sulle travi (le bielle, scariche, portano $N$ uniforme: $N_{AC}=N_{BG}=-\tfrac {5\sqrt 5}{12}$, $N_{AD}=N_{BF}=-\tfrac {25\sqrt {17}}{12}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$; i diagrammi $N$ e $M$ simmetrici rispetto a $E$, quello di $T$ è emisimmetrico}{figure.caption.174}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.22}{\ignorespaces Caso (b), carico $p$ sul tratto centrale $DEF$ --- (a) schema e reazioni ($V_A=V_B=p\ell $, $H_A=H_B=6p\ell $); (b) sforzo normale $N$ (le bielle, scariche, portano $N$ uniforme: $N_{AC}=N_{BG}=+\tfrac  {\sqrt  5}{3}$, $N_{AD}=N_{BF}=-\tfrac  {4\sqrt  {17}}{3}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$ e ovunque non positivo (estradosso teso, lineare su $CD$, $FG$); $N$ e $M$ simmetrici rispetto a $E$, $T$ emisimmetrico.}}{453}{figure.caption.175}\protected@file@percent }
\newlabel{fig:stampella_NTM_b}{{17.22}{453}{Caso (b), carico $p$ sul tratto centrale $DEF$ --- (a) schema e reazioni ($V_A=V_B=p\ell $, $H_A=H_B=6p\ell $); (b) sforzo normale $N$ (le bielle, scariche, portano $N$ uniforme: $N_{AC}=N_{BG}=+\tfrac {\sqrt 5}{3}$, $N_{AD}=N_{BF}=-\tfrac {4\sqrt {17}}{3}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$ e ovunque non positivo (estradosso teso, lineare su $CD$, $FG$); $N$ e $M$ simmetrici rispetto a $E$, $T$ emisimmetrico}{figure.caption.175}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.23}{\ignorespaces Caso (c), carico asimmetrico ($p$ su $CD$ ed $EF$) --- (a) schema con carichi e reazioni; (b) sforzo normale $N$ sulle travi (le bielle, scariche, portano $N$ costante: $N_{AC}=-\tfrac  {9\sqrt  5}{16}$, $N_{AD}=-\tfrac  {39\sqrt  {17}}{32}$, $N_{BF}=-\tfrac  {83\sqrt  {17}}{96}$, $N_{BG}=+\tfrac  {7\sqrt  5}{48}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$.}}{455}{figure.caption.176}\protected@file@percent }
\newlabel{fig:stampella_NTM_c}{{17.23}{455}{Caso (c), carico asimmetrico ($p$ su $CD$ ed $EF$) --- (a) schema con carichi e reazioni; (b) sforzo normale $N$ sulle travi (le bielle, scariche, portano $N$ costante: $N_{AC}=-\tfrac {9\sqrt 5}{16}$, $N_{AD}=-\tfrac {39\sqrt {17}}{32}$, $N_{BF}=-\tfrac {83\sqrt {17}}{96}$, $N_{BG}=+\tfrac {7\sqrt 5}{48}$, in $p\ell $); (c) taglio $T$; (d) momento flettente $M$, dal lato delle fibre tese. Scale indipendenti; $M=0$ alle cerniere $C$, $E$, $G$}{figure.caption.176}{}}
\newlabel{ex:stampella_progetto}{{17.2}{456}{Conformazione geometrica per un impalcato compresso}{esercizioinner.17.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.24}{\ignorespaces Sintesi del segno al nodo $A$. \emph  {(In alto)} Lettura geometrica: la retta d'azione di $\mathbf  r_A$, prolungata fino all'impalcato, cade entro il segmento $CD$ (spinta nel ventaglio, $AC$ compressa) oppure oltre $D$ ($AC$ tesa, impalcato compresso); il triangolo $A$--$C$--$D$ è l'anello a tre cerniere d'imposta. Sono quotati lo sbalzo $\beta $ della biella interna e il ribassamento $f$, i due parametri della soglia $H_A/V_A=\beta /f$. \emph  {(In basso)} Poligoni di equilibrio del nodo $A$: a sinistra $\mathbf  r_A$ è nel ventaglio e le bielle $AC$, $AD$ sono entrambe compresse (carico su $CG$); a destra $\mathbf  r_A$ ne esce oltre $AD$ e la biella esterna $AC$ si inverte in tirante (carico su $DF$). In ciascun poligono la reazione $\mathbf  r_A$ è scomposta lungo le rette delle due bielle (parallelogramma): le componenti $N_{AC}$, $N_{AD}$ vi giacciono e quella di $N_{AD}$, prolungata, passa per $D$. Una componente concorde con la propria biella, verso $C$ o $D$, indica biella compressa; discorde, biella tesa.}}{457}{figure.caption.177}\protected@file@percent }
\newlabel{fig:stampella_ventaglio}{{17.24}{457}{Sintesi del segno al nodo $A$. \emph {(In alto)} Lettura geometrica: la retta d'azione di $\mathbf r_A$, prolungata fino all'impalcato, cade entro il segmento $CD$ (spinta nel ventaglio, $AC$ compressa) oppure oltre $D$ ($AC$ tesa, impalcato compresso); il triangolo $A$--$C$--$D$ è l'anello a tre cerniere d'imposta. Sono quotati lo sbalzo $\beta $ della biella interna e il ribassamento $f$, i due parametri della soglia $H_A/V_A=\beta /f$. \emph {(In basso)} Poligoni di equilibrio del nodo $A$: a sinistra $\mathbf r_A$ è nel ventaglio e le bielle $AC$, $AD$ sono entrambe compresse (carico su $CG$); a destra $\mathbf r_A$ ne esce oltre $AD$ e la biella esterna $AC$ si inverte in tirante (carico su $DF$). In ciascun poligono la reazione $\mathbf r_A$ è scomposta lungo le rette delle due bielle (parallelogramma): le componenti $N_{AC}$, $N_{AD}$ vi giacciono e quella di $N_{AD}$, prolungata, passa per $D$. Una componente concorde con la propria biella, verso $C$ o $D$, indica biella compressa; discorde, biella tesa}{figure.caption.177}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.25}{\ignorespaces Confronto dei due funzionamenti sulla stessa struttura: tratto spesso = compressione (puntone), sottile = trazione (tirante). \emph  {(a)} carico sull'intera travata $C$--$G$: bielle d'imposta tutte compresse e corrente centrale $DEF$ compresso ($N=-\tfrac  {15}{2}p\ell $), con i soli tratti $CD$, $FG$ tesi a catena locale degli anelli $A$--$C$--$D$ e $B$--$F$--$G$. \emph  {(b)} carico sul solo $DF$: l'intera navata $C$--$G$ è compressa ($N=-6\,p\ell $ in mezzeria) con le bielle interne $AD$, $BF$; si fanno tese le sole bielle d'estremità $AC$, $BG$. È lo specchio di~(a), con i ruoli di catena e puntone scambiati fra navata e bielle.}}{458}{figure.caption.178}\protected@file@percent }
\newlabel{fig:stampella_funzionamento}{{17.25}{458}{Confronto dei due funzionamenti sulla stessa struttura: tratto spesso = compressione (puntone), sottile = trazione (tirante). \emph {(a)} carico sull'intera travata $C$--$G$: bielle d'imposta tutte compresse e corrente centrale $DEF$ compresso ($N=-\tfrac {15}{2}p\ell $), con i soli tratti $CD$, $FG$ tesi a catena locale degli anelli $A$--$C$--$D$ e $B$--$F$--$G$. \emph {(b)} carico sul solo $DF$: l'intera navata $C$--$G$ è compressa ($N=-6\,p\ell $ in mezzeria) con le bielle interne $AD$, $BF$; si fanno tese le sole bielle d'estremità $AC$, $BG$. È lo specchio di~(a), con i ruoli di catena e puntone scambiati fra navata e bielle}{figure.caption.178}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.26}{\ignorespaces Parametri geometrici dell'arco a tre cerniere: ribassamento $f$, sbalzo esterno $\alpha $ e interno $\beta $, luce degli appoggi $L$. Ne discendono $\overline  {CG}=L+2\alpha $ e $\overline  {DF}=L-2\beta $; il criterio $\overline  {DF}>\tfrac  12\overline  {CG}$ assicura impalcato compresso sotto peso proprio.}}{458}{figure.caption.179}\protected@file@percent }
\newlabel{fig:stampella_param}{{17.26}{458}{Parametri geometrici dell'arco a tre cerniere: ribassamento $f$, sbalzo esterno $\alpha $ e interno $\beta $, luce degli appoggi $L$. Ne discendono $\overline {CG}=L+2\alpha $ e $\overline {DF}=L-2\beta $; il criterio $\overline {DF}>\tfrac 12\overline {CG}$ assicura impalcato compresso sotto peso proprio}{figure.caption.179}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.27}{\ignorespaces Commutazione del segno di $N_{AC}$ al variare dello sbalzo interno $\beta $ ($L=4\ell $, $\alpha =\ell /2$, $f=\ell /4$). Per ciascuno scenario $AC$ è \emph  {tesa} dove la curva $H/V_A$ sta \emph  {sopra} la retta soglia $\beta /f$. Il peso proprio ($CG$, costante $=3$) supera la soglia solo per $\beta <\beta ^\ast =\tfrac  34\ell $; il carico centrale ($DF$) la supera sempre. Il dimensionamento $\beta =\tfrac  12\ell $ cade nella regione favorevole, quello originario $\beta =\ell $ no.}}{460}{figure.caption.180}\protected@file@percent }
\newlabel{fig:stampella_commutazione}{{17.27}{460}{Commutazione del segno di $N_{AC}$ al variare dello sbalzo interno $\beta $ ($L=4\ell $, $\alpha =\ell /2$, $f=\ell /4$). Per ciascuno scenario $AC$ è \emph {tesa} dove la curva $H/V_A$ sta \emph {sopra} la retta soglia $\beta /f$. Il peso proprio ($CG$, costante $=3$) supera la soglia solo per $\beta <\beta ^\ast =\tfrac 34\ell $; il carico centrale ($DF$) la supera sempre. Il dimensionamento $\beta =\tfrac 12\ell $ cade nella regione favorevole, quello originario $\beta =\ell $ no}{figure.caption.180}{}}
