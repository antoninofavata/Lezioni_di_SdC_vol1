\@writefile{lof}{\contentsline {figure}{\numberline {6.15}{\ignorespaces Arco a tutto sesto con incastro: contributi separati dei due cedimenti al metodo grafo-analitico. \emph  {(a)}~Contributo $\bar  {v}_A$: $\mathcal  {C}_1$ trasla verso il basso ($C_1$ punto improprio di $x$); $\mathcal  {C}_2$ ruota attorno a $C_2^{(1)}$ (intersezione dell'orizzontale per $C$ con la verticale per $B$); su $r_H$ sono riportate le tracce di $C_{12}\equiv C$ e $C_2^{(1)}$ e i campi $u$ e $v$ di $\mathcal  {C}_1$ e $\mathcal  {C}_2$. \emph  {(b)}~Contributo $\bar  {v}_B$: $\mathcal  {C}_1$ fisso, $C$ fisso; $\mathcal  {C}_2$ ruota attorno a $C_2^{(2)}\equiv C$; su $r_H$ sono riportate la traccia di $C_2^{(2)}\equiv C$ e i campi $u$ e $v$ di $\mathcal  {C}_2$.}}{159}{figure.caption.64}\protected@file@percent }
\newlabel{fig:arco_incastro_grafo}{{6.15}{159}{Arco a tutto sesto con incastro: contributi separati dei due cedimenti al metodo grafo-analitico. \emph {(a)}~Contributo $\bar {v}_A$: $\mathcal {C}_1$ trasla verso il basso ($C_1$ punto improprio di $x$); $\mathcal {C}_2$ ruota attorno a $C_2^{(1)}$ (intersezione dell'orizzontale per $C$ con la verticale per $B$); su $r_H$ sono riportate le tracce di $C_{12}\equiv C$ e $C_2^{(1)}$ e i campi $u$ e $v$ di $\mathcal {C}_1$ e $\mathcal {C}_2$. \emph {(b)}~Contributo $\bar {v}_B$: $\mathcal {C}_1$ fisso, $C$ fisso; $\mathcal {C}_2$ ruota attorno a $C_2^{(2)}\equiv C$; su $r_H$ sono riportate la traccia di $C_2^{(2)}\equiv C$ e i campi $u$ e $v$ di $\mathcal {C}_2$}{figure.caption.64}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.16}{\ignorespaces Arco a tutto sesto con incastro: schemi dei corpi liberi di $\mathcal  {C}_2$ \emph  {(a)} e $\mathcal  {C}_1$ \emph  {(b)}. La cascata statica procede da $\mathcal  {C}_2$ a $\mathcal  {C}_1$, in ordine inverso rispetto alla cinematica; polo di momento in $C$ per $\mathcal  {C}_2$, in $A$ per $\mathcal  {C}_1$.}}{160}{figure.caption.65}\protected@file@percent }
\newlabel{fig:arco_incastro_cl}{{6.16}{160}{Arco a tutto sesto con incastro: schemi dei corpi liberi di $\mathcal {C}_2$ \emph {(a)} e $\mathcal {C}_1$ \emph {(b)}. La cascata statica procede da $\mathcal {C}_2$ a $\mathcal {C}_1$, in ordine inverso rispetto alla cinematica; polo di momento in $C$ per $\mathcal {C}_2$, in $A$ per $\mathcal {C}_1$}{figure.caption.65}{}}
