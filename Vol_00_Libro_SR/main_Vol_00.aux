\newlabel{eq:bilancio_lavori}{{5.25}{108}{Struttura duale dei due problemi}{equation.5.4.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Struttura duale dei problemi cinematico $\bm  {A}\bm  {u} = \bm  {s}$ e statico $\bm  {A}^\top \bm  {r} = -\bm  {f}$. Il problema cinematico ammette soluzione se e solo se $\bm  {s}_c \in \mathcal  {I}(\bm  {A})$, cioè $\bm  {s}_n = \bm  {0}$: il cedimento deve essere cinematicamente ammissibile. Il problema statico ammette soluzione se e solo se $\bm  {f}_c \in \mathcal  {I}(\bm  {A}^\top )$, cioè $\bm  {f}_n = \bm  {0}$: la forza attiva deve essere equilibrabile dai vincoli. Le soluzioni generali sono $\bm  {u} = \bm  {u}_c + \bm  {u}_n$ con $\bm  {u}_n \in \mathcal  {N}(\bm  {A})$ (meccanismo) arbitrario, e $\bm  {r} = \bm  {r}_c + \bm  {r}_n$ con $\bm  {r}_n \in \mathcal  {N}(\bm  {A}^\top )$ (stato di autoequilibrio) arbitrario.}}{109}{figure.caption.41}\protected@file@percent }
\newlabel{fig:problemi_duali_SCR}{{5.2}{109}{Struttura duale dei problemi cinematico $\bm {A}\bm {u} = \bm {s}$ e statico $\bm {A}^\top \bm {r} = -\bm {f}$. Il problema cinematico ammette soluzione se e solo se $\bm {s}_c \in \Ic (\bm {A})$, cioè $\bm {s}_n = \bm {0}$: il cedimento deve essere cinematicamente ammissibile. Il problema statico ammette soluzione se e solo se $\bm {f}_c \in \Ic (\bm {A}^\top )$, cioè $\bm {f}_n = \bm {0}$: la forza attiva deve essere equilibrabile dai vincoli. Le soluzioni generali sono $\bm {u} = \bm {u}_c + \bm {u}_n$ con $\bm {u}_n \in \Nc (\bm {A})$ (meccanismo) arbitrario, e $\bm {r} = \bm {r}_c + \bm {r}_n$ con $\bm {r}_n \in \Nc (\bm {A}^\top )$ (stato di autoequilibrio) arbitrario}{figure.caption.41}{}}
