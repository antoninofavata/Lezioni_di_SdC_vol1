\@writefile{lof}{\contentsline {figure}{\numberline {17.15}{\ignorespaces Trave di Gerber su quattro appoggi ($n_a=4$, $n_e=5$, $n_c=2$): cerniera in $A$, appoggi continui in $B$ e $C$, carrello in $D$, cerniere interne in $E$ e $F$. Luci: $AB = CD = \ell $, $BE = FC = \ell /2$, $EF = 2\ell $. La campata portata $EF$ è soggetta a un carico trasversale triangolare di intensità massima $p$ nella sezione di mezzeria e nulla agli estremi $E$ e $F$.}}{439}{figure.caption.168}\protected@file@percent }
\newlabel{fig:gerber_esempio_schema}{{17.15}{439}{Trave di Gerber su quattro appoggi ($n_a=4$, $n_e=5$, $n_c=2$): cerniera in $A$, appoggi continui in $B$ e $C$, carrello in $D$, cerniere interne in $E$ e $F$. Luci: $AB = CD = \ell $, $BE = FC = \ell /2$, $EF = 2\ell $. La campata portata $EF$ è soggetta a un carico trasversale triangolare di intensità massima $p$ nella sezione di mezzeria e nulla agli estremi $E$ e $F$}{figure.caption.168}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {17.16}{\ignorespaces Trave di Gerber: schema delle reazioni (\emph  {prima riga}), taglio $T$ (\emph  {seconda riga}) e momento $M$ (\emph  {terza riga}). Le reazioni $V_A=V_D=p\ell /4$ verso il basso indicano che i perni $A$ e $D$ trattengono la trave. Il taglio è emisimmetrico; il momento è simmetrico, nullo in $E$ e $F$, con massimo $p\ell ^2/3$ (sagging) a mezzeria di $EF$ e valore $p\ell ^2/4$ (hogging) agli appoggi $B$ e $C$.}}{441}{figure.caption.169}\protected@file@percent }
\newlabel{fig:gerber_esempio_diagrammi}{{17.16}{441}{Trave di Gerber: schema delle reazioni (\emph {prima riga}), taglio $T$ (\emph {seconda riga}) e momento $M$ (\emph {terza riga}). Le reazioni $V_A=V_D=p\ell /4$ verso il basso indicano che i perni $A$ e $D$ trattengono la trave. Il taglio è emisimmetrico; il momento è simmetrico, nullo in $E$ e $F$, con massimo $p\ell ^2/3$ (sagging) a mezzeria di $EF$ e valore $p\ell ^2/4$ (hogging) agli appoggi $B$ e $C$}{figure.caption.169}{}}
