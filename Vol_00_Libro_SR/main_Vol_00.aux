\@writefile{toc}{\contentsline {subsubsection}{Il traliccio di Ritter-M\"{o}rsch come travatura di Warren}{502}{equation.18.8.20}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {18.17}{\ignorespaces Traliccio di Ritter-M\"{o}rsch con carichi $P$ applicati ai nodi del corrente superiore ($F$, $G$, $H$, $I$) e reazioni $2P$ agli appoggi $A$ ed $E$. Le quote orizzontali indicano le proiezioni delle diagonali: $b = \cot \vartheta $ per i puntoni (tratto spesso, compressi) e $a = \cot \alpha $ per le staffe (tratto sottile, tese). Il diagramma del taglio è positivo nella metà sinistra ($2P$ nel primo pannello, $P$ nel secondo) e nullo tra i nodi $G$ e $H$; per antisimmetria è negativo nella metà destra. Il poligono del momento ha tetto piatto di valore $(a+3b)P$ tra $G$ e $H$, dove il taglio è nullo, e valori nodali $(a+2b)P$ in $B$ e $D$, $2bP$ in $F$ e $I$.}}{503}{figure.caption.197}\protected@file@percent }
\newlabel{fig:traliccio_Morsch}{{18.17}{503}{Traliccio di Ritter-M\"{o}rsch con carichi $P$ applicati ai nodi del corrente superiore ($F$, $G$, $H$, $I$) e reazioni $2P$ agli appoggi $A$ ed $E$. Le quote orizzontali indicano le proiezioni delle diagonali: $b = \cot \vartheta $ per i puntoni (tratto spesso, compressi) e $a = \cot \alpha $ per le staffe (tratto sottile, tese). Il diagramma del taglio è positivo nella metà sinistra ($2P$ nel primo pannello, $P$ nel secondo) e nullo tra i nodi $G$ e $H$; per antisimmetria è negativo nella metà destra. Il poligono del momento ha tetto piatto di valore $(a+3b)P$ tra $G$ e $H$, dove il taglio è nullo, e valori nodali $(a+2b)P$ in $B$ e $D$, $2bP$ in $F$ e $I$}{figure.caption.197}{}}
\newlabel{eq:triangolo_forze}{{18.21}{504}{Il traliccio di Ritter-M\"{o}rsch come travatura di Warren}{equation.18.8.21}{}}
\newlabel{eq:Np_Ns}{{18.22}{504}{Il traliccio di Ritter-M\"{o}rsch come travatura di Warren}{equation.18.8.22}{}}
\newlabel{eq:Np_Ns_vert}{{18.23}{504}{Il traliccio di Ritter-M\"{o}rsch come travatura di Warren}{equation.18.8.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18.18}{\ignorespaces Maglia elementare del traliccio di Ritter-Mörsch e poligono delle forze al nodo del corrente superiore. \emph  {Pannello sinistro}: la variazione di sforzo $\Delta N$ nei correnti --- uguale in valore assoluto nel corrente superiore compresso e in quello inferiore teso --- deve essere equilibrata dalle componenti orizzontali del puntone (tratto spesso, angolo $\vartheta $) e della staffa (tratto sottile, angolo $\alpha $). \emph  {Pannello destro}: poligono chiuso delle forze al nodo; l'angolo al vertice opposto a $\Delta N$ vale $\pi - (\vartheta +\alpha )$, donde per il teorema dei seni le~\eqref  {eq:Np_Ns}.}}{504}{figure.caption.198}\protected@file@percent }
\newlabel{fig:maglia_Morsch}{{18.18}{504}{Maglia elementare del traliccio di Ritter-Mörsch e poligono delle forze al nodo del corrente superiore. \emph {Pannello sinistro}: la variazione di sforzo $\Delta N$ nei correnti --- uguale in valore assoluto nel corrente superiore compresso e in quello inferiore teso --- deve essere equilibrata dalle componenti orizzontali del puntone (tratto spesso, angolo $\vartheta $) e della staffa (tratto sottile, angolo $\alpha $). \emph {Pannello destro}: poligono chiuso delle forze al nodo; l'angolo al vertice opposto a $\Delta N$ vale $\pi - (\vartheta +\alpha )$, donde per il teorema dei seni le~\eqref {eq:Np_Ns}}{figure.caption.198}{}}
