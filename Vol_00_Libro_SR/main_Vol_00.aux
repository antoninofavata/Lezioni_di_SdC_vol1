\@writefile{lof}{\contentsline {figure}{\numberline {1.12}{\ignorespaces Riflessione rispetto al piano $\uppi $ di normale $\mathbf  {n}$. In alto: il vettore polare $\mathbf  {v}$, applicato in $P$, si trasforma nel simmetrico $\mathbf  {R}_{\mathbf  {n}}\mathbf  {v}$, applicato nel punto simmetrico $P_\star $: la componente parallela al piano resta invariata, quella normale si inverte. In basso: i riflessi $\mathbf  {R}_{\mathbf  {n}}\mathbf  {v}$ e $\mathbf  {R}_{\mathbf  {n}}\mathbf  {w}$ definiscono una circolazione di verso opposto, e il vettore assiale $\bm  {\upomega }=\mathbf  {v}\times \mathbf  {w}$ si trasforma nell'antisimmetrico $\bm  {\upomega }_\star =-\mathbf  {R}_{\mathbf  {n}}(\bm  {\upomega })$.}}{15}{figure.caption.13}\protected@file@percent }
\newlabel{fig:riflessione}{{1.12}{15}{Riflessione rispetto al piano $\uppi $ di normale $\nb $. In alto: il vettore polare $\vb $, applicato in $P$, si trasforma nel simmetrico $\Rbb _{\nb }\vb $, applicato nel punto simmetrico $P_\star $: la componente parallela al piano resta invariata, quella normale si inverte. In basso: i riflessi $\Rbb _{\nb }\vb $ e $\Rbb _{\nb }\wb $ definiscono una circolazione di verso opposto, e il vettore assiale $\bm {\upomega }=\vb \times \wb $ si trasforma nell'antisimmetrico $\bm {\upomega }_\star =-\Rbb _{\nb }(\bm {\upomega })$}{figure.caption.13}{}}
\newlabel{eq:rif_assiale}{{1.25}{15}{Comportamento sotto riflessione}{equation.1.3.25}{}}
