\@writefile{lof}{\contentsline {figure}{\numberline {7.6}{\ignorespaces Trasporto di una forza in un punto non appartenente alla linea d'azione. \textbf  {\textit  {(a)}}~Sistema originale: forza $\mathbf  {f}$ applicata in $P$. \textbf  {\textit  {(b)}}~Aggiunta in $Q$ della coppia equilibrata $(\mathbf  {f},\,-\mathbf  {f})$: la forza $(P,\,\mathbf  {f})$ e $(Q,\,-\mathbf  {f})$ formano una coppia di momento $\bm  {\upmu } = \overrightarrow {QP}\times \mathbf  {f}$, con braccio $b$. \textbf  {\textit  {(c)}}~Sistema equivalente: forza $\mathbf  {f}$ applicata in $Q$ più la coppia correttiva oraria di intensità $\mu (Q) = |\mathbf  {f}|\,b$.}}{145}{figure.caption.39}\protected@file@percent }
\newlabel{fig:trasporto_forza}{{7.6}{145}{Trasporto di una forza in un punto non appartenente alla linea d'azione. \textbf {\textit {(a)}}~Sistema originale: forza $\fb $ applicata in $P$. \textbf {\textit {(b)}}~Aggiunta in $Q$ della coppia equilibrata $(\fb ,\,-\fb )$: la forza $(P,\,\fb )$ e $(Q,\,-\fb )$ formano una coppia di momento $\bm {\upmu } = \protect \overrightarrow {QP}\times \fb $, con braccio $b$. \textbf {\textit {(c)}}~Sistema equivalente: forza $\fb $ applicata in $Q$ più la coppia correttiva oraria di intensità $\mu (Q) = |\fb |\,b$}{figure.caption.39}{}}
