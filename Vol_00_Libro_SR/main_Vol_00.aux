\@writefile{lof}{\contentsline {figure}{\numberline {1.1}{\ignorespaces \textbf  {\textit  {(a)}}~Rappresentazione geometrica di una traslazione e di una rotazione finita nel piano, dove il punto $O$ si sposta in $O_*$ e il punto $P$ si sposta in $P_*$, con origine del sistema di riferimento in $\Omega $. Il vettore $\mathbf  {u}(O)$ rappresenta la traslazione di $O$, mentre $\mathbf  {u}(P)$ è lo spostamento totale di $P$, e $\mathbf  {R}\overrightarrow {OP}$ è il vettore $\overrightarrow {OP}$ ruotato di $\vartheta $. \textbf  {\textit  {(b)}}~Scomposizione dello spostamento del punto $P$ in $P_*$ come somma della traslazione $\mathbf  {u}(O)$ e della rotazione, con la componente rotazionale decomposta nelle direzioni ortogonale ($|\overrightarrow {OP}|\sin \vartheta $) e parallela ($|\overrightarrow {OP}|(1-\cos \vartheta )$) rispetto al vettore posizione $\overrightarrow {OP}$.}}{12}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:spostamenti_finiti}{{1.1}{12}{\textbf {\textit {(a)}}~Rappresentazione geometrica di una traslazione e di una rotazione finita nel piano, dove il punto $O$ si sposta in $O_*$ e il punto $P$ si sposta in $P_*$, con origine del sistema di riferimento in $\Omega $. Il vettore $\ub (O)$ rappresenta la traslazione di $O$, mentre $\ub (P)$ è lo spostamento totale di $P$, e $\Rbb \protect \overrightarrow {OP}$ è il vettore $\protect \overrightarrow {OP}$ ruotato di $\vartheta $. \textbf {\textit {(b)}}~Scomposizione dello spostamento del punto $P$ in $P_*$ come somma della traslazione $\ub (O)$ e della rotazione, con la componente rotazionale decomposta nelle direzioni ortogonale ($|\protect \overrightarrow {OP}|\sin \vartheta $) e parallela ($|\protect \overrightarrow {OP}|(1-\cos \vartheta )$) rispetto al vettore posizione $\protect \overrightarrow {OP}$}{figure.caption.3}{}}
\newlabel{eq:FFCI}{{1.7}{12}{Generalizzazione al caso tridimensionale}{equation.1.3.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.2}{\ignorespaces Interpretazione geometrica del termine rotazionale $\bm  {\upvartheta } \times \overrightarrow {OP}$: la componente $\overrightarrow {OP}_{\!\perp }$, ortogonale all'asse di rotazione, determina la distanza $d$ del punto $P$ dall'asse; lo spostamento rotazionale ha modulo $|\bm  {\upvartheta }|\,d$ ed è tangente alla circonferenza di raggio $d$.}}{13}{figure.caption.4}\protected@file@percent }
\newlabel{fig:termine_rotazionale}{{1.2}{13}{Interpretazione geometrica del termine rotazionale $\bm {\upvartheta } \times \protect \overrightarrow {OP}$: la componente $\protect \overrightarrow {OP}_{\!\perp }$, ortogonale all'asse di rotazione, determina la distanza $d$ del punto $P$ dall'asse; lo spostamento rotazionale ha modulo $|\bm {\upvartheta }|\,d$ ed è tangente alla circonferenza di raggio $d$}{figure.caption.4}{}}
