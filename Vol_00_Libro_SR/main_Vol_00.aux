\@writefile{toc}{\contentsline {subsection}{\numberline {15.3.3}Proprietà di tangenza del diagramma del momento}{358}{subsection.15.3.3}\protected@file@percent }
\newlabel{sec:tangenze_momento}{{15.3.3}{358}{Proprietà di tangenza del diagramma del momento}{subsection.15.3.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.13}{\ignorespaces Le due proprietà di tangenza del diagramma del momento su un tratto generico $[z_1, z_2]$ di una trave sotto carico uniforme. (a)~\emph  {Tangenza agli estremi:} la parabola del momento (linea nera) e la spezzata di sostituzione (linea grigia continua), ottenuta sostituendo il carico distribuito con la sua risultante applicata nel baricentro $z_G$ del tratto, sono tangenti agli estremi $z_1$ e $z_2$, dove i valori del momento e le pendenze coincidono; la spezzata si raccorda sulla verticale di $z_G$. (b)~\emph  {Tangenza in mezzeria:} la corda che congiunge le ordinate del diagramma in $z_1$ e $z_2$ (tratto grigio tratteggiato superiore) è parallela alla tangente alla parabola in mezzeria $(z_1+z_2)/2$ (tratto grigio tratteggiato inferiore).}}{359}{figure.caption.125}\protected@file@percent }
\newlabel{fig:stat_tangenze}{{15.13}{359}{Le due proprietà di tangenza del diagramma del momento su un tratto generico $[z_1, z_2]$ di una trave sotto carico uniforme. (a)~\emph {Tangenza agli estremi:} la parabola del momento (linea nera) e la spezzata di sostituzione (linea grigia continua), ottenuta sostituendo il carico distribuito con la sua risultante applicata nel baricentro $z_G$ del tratto, sono tangenti agli estremi $z_1$ e $z_2$, dove i valori del momento e le pendenze coincidono; la spezzata si raccorda sulla verticale di $z_G$. (b)~\emph {Tangenza in mezzeria:} la corda che congiunge le ordinate del diagramma in $z_1$ e $z_2$ (tratto grigio tratteggiato superiore) è parallela alla tangente alla parabola in mezzeria $(z_1+z_2)/2$ (tratto grigio tratteggiato inferiore)}{figure.caption.125}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.14}{\ignorespaces Trave appoggiata, confronto fra carico distribuito uniforme $\bar  {p}$ (caso~a, tratto nero) e risultante concentrata $R = \bar  {p}\ell $ applicata in mezzeria (caso~b, tratto grigio): (a)~schema strutturale con i due sistemi di carico sovrapposti; (b)~diagrammi del taglio $T(z)$; (c)~diagrammi del momento $M(z)$, con la tangente orizzontale al vertice della parabola del caso~(a) (tratto grigio tratteggiato), parallela alla corda $A$--$B$ che congiunge le ordinate estreme del diagramma.}}{361}{figure.caption.126}\protected@file@percent }
\newlabel{fig:stat_confronto_01}{{15.14}{361}{Trave appoggiata, confronto fra carico distribuito uniforme $\bar {p}$ (caso~a, tratto nero) e risultante concentrata $R = \bar {p}\ell $ applicata in mezzeria (caso~b, tratto grigio): (a)~schema strutturale con i due sistemi di carico sovrapposti; (b)~diagrammi del taglio $T(z)$; (c)~diagrammi del momento $M(z)$, con la tangente orizzontale al vertice della parabola del caso~(a) (tratto grigio tratteggiato), parallela alla corda $A$--$B$ che congiunge le ordinate estreme del diagramma}{figure.caption.126}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.15}{\ignorespaces Mensola, confronto fra carico distribuito uniforme $\bar  {p}$ (caso~a, tratto nero) e risultante concentrata $R = \bar  {p}\ell $ applicata in mezzeria (caso~b, tratto grigio): (a)~schema strutturale con i due sistemi di carico sovrapposti; (b)~diagrammi del taglio $T(z)$; (c)~diagrammi del momento $M(z)$. I due diagrammi del momento sono tangenti agli estremi della mensola ($A$ e $B$); la corda del diagramma che congiunge $M(A) = -\bar  p\ell ^2/2$ a $M(B) = 0$ (tratto grigio tratteggiato superiore) è parallela alla tangente al vertice della parabola in mezzeria (tratto grigio tratteggiato inferiore), in accordo con la proprietà di tangenza in mezzeria delle parabole da carico uniforme.}}{363}{figure.caption.127}\protected@file@percent }
\newlabel{fig:stat_confronto_02}{{15.15}{363}{Mensola, confronto fra carico distribuito uniforme $\bar {p}$ (caso~a, tratto nero) e risultante concentrata $R = \bar {p}\ell $ applicata in mezzeria (caso~b, tratto grigio): (a)~schema strutturale con i due sistemi di carico sovrapposti; (b)~diagrammi del taglio $T(z)$; (c)~diagrammi del momento $M(z)$. I due diagrammi del momento sono tangenti agli estremi della mensola ($A$ e $B$); la corda del diagramma che congiunge $M(A) = -\bar p\ell ^2/2$ a $M(B) = 0$ (tratto grigio tratteggiato superiore) è parallela alla tangente al vertice della parabola in mezzeria (tratto grigio tratteggiato inferiore), in accordo con la proprietà di tangenza in mezzeria delle parabole da carico uniforme}{figure.caption.127}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.16}{\ignorespaces Trave appoggiata con carico uniforme $\bar  p$ e coppie antiorarie $\mu (A) = \mu (B) = \bar  p \ell ^2/8$ agli estremi (caso~a, tratto nero) confrontata con la stessa trave in cui il carico è sostituito dalla risultante $R = \bar  p \ell $ in mezzeria (caso~b, tratto grigio): (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento, con la corda $M(A)$--$M(B)$ e la tangente alla parabola in $\ell /2$ (linee grigie sottili) parallele tra loro.}}{365}{figure.caption.128}\protected@file@percent }
\newlabel{fig:stat_sovrapposizione_01}{{15.16}{365}{Trave appoggiata con carico uniforme $\bar p$ e coppie antiorarie $\mu (A) = \mu (B) = \bar p \ell ^2/8$ agli estremi (caso~a, tratto nero) confrontata con la stessa trave in cui il carico è sostituito dalla risultante $R = \bar p \ell $ in mezzeria (caso~b, tratto grigio): (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento, con la corda $M(A)$--$M(B)$ e la tangente alla parabola in $\ell /2$ (linee grigie sottili) parallele tra loro}{figure.caption.128}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.17}{\ignorespaces Trave con sbalzo destro e carico uniforme $\bar  p$ (caso~a, tratto nero) confrontata con la sostituzione del carico distribuito su ciascun tratto con la propria risultante in mezzeria (caso~b, tratto grigio): risultante $\bar  p\ell $ in $\ell /2$ per la campata $AC$ e risultante $\bar  p\ell /2$ in $5\ell /4$ per lo sbalzo $CB$. (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento. I due segmenti della spezzata grigia su $AC$ sono tangenti alla parabola in $A$ e in $C^-$; analogamente i due segmenti su $CB$ sono tangenti in $C^+$ e in $B$. Sul tratto $AC$ sono inoltre tracciate (tratti grigi tratteggiati) la corda dei momenti d'estremità $A$--$C$ e la tangente parallela alla parabola in $\ell /2$.}}{368}{figure.caption.129}\protected@file@percent }
\newlabel{fig:stat_sbalzo_01}{{15.17}{368}{Trave con sbalzo destro e carico uniforme $\bar p$ (caso~a, tratto nero) confrontata con la sostituzione del carico distribuito su ciascun tratto con la propria risultante in mezzeria (caso~b, tratto grigio): risultante $\bar p\ell $ in $\ell /2$ per la campata $AC$ e risultante $\bar p\ell /2$ in $5\ell /4$ per lo sbalzo $CB$. (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento. I due segmenti della spezzata grigia su $AC$ sono tangenti alla parabola in $A$ e in $C^-$; analogamente i due segmenti su $CB$ sono tangenti in $C^+$ e in $B$. Sul tratto $AC$ sono inoltre tracciate (tratti grigi tratteggiati) la corda dei momenti d'estremità $A$--$C$ e la tangente parallela alla parabola in $\ell /2$}{figure.caption.129}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15.18}{\ignorespaces Trave con doppio sbalzo simmetrico e carico uniforme $\bar  p$ (caso~a, tratto nero) confrontata con la sostituzione di ogni carico distribuito con la propria risultante applicata nel baricentro del tratto: $\bar  p\ell /2$ in mezzeria di $AB$ e di $CD$, $\bar  p\ell $ in mezzeria di $BC$ (caso~b, tratto grigio). (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento. Ogni segmento della spezzata grigia del momento è tangente alla parabola caso~(a) in uno dei punti $\{A,\,B^-,\,B^+,\,C^-,\,C^+,\,D\}$. Sul tratto centrale $BC$ è inoltre tracciata (tratto grigio tratteggiato) la corda dei momenti d'estremità, retta orizzontale a quota $-\bar  p\ell ^2/8$; la tangente parallela alla parabola in mezzeria di $BC$ coincide con l'asse della trave (poiché $T(\ell ) = 0$) e non è disegnata separatamente.}}{370}{figure.caption.130}\protected@file@percent }
\newlabel{fig:stat_sbalzo_02}{{15.18}{370}{Trave con doppio sbalzo simmetrico e carico uniforme $\bar p$ (caso~a, tratto nero) confrontata con la sostituzione di ogni carico distribuito con la propria risultante applicata nel baricentro del tratto: $\bar p\ell /2$ in mezzeria di $AB$ e di $CD$, $\bar p\ell $ in mezzeria di $BC$ (caso~b, tratto grigio). (a)~schema strutturale; (b)~diagrammi del taglio; (c)~diagrammi del momento. Ogni segmento della spezzata grigia del momento è tangente alla parabola caso~(a) in uno dei punti $\{A,\,B^-,\,B^+,\,C^-,\,C^+,\,D\}$. Sul tratto centrale $BC$ è inoltre tracciata (tratto grigio tratteggiato) la corda dei momenti d'estremità, retta orizzontale a quota $-\bar p\ell ^2/8$; la tangente parallela alla parabola in mezzeria di $BC$ coincide con l'asse della trave (poiché $T(\ell ) = 0$) e non è disegnata separatamente}{figure.caption.130}{}}
