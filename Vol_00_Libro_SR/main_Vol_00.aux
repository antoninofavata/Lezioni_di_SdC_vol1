\@writefile{lof}{\contentsline {figure}{\numberline {15.11}{\ignorespaces Trave appoggiata con coppie concentrate antiorarie $\mu _A$ in $A$ e $\mu _B$ in $B$: (a)~schema strutturale; (b)~diagramma del taglio $T(z)$, uniforme pari a $(\mu _A + \mu _B)/\ell $ su tutta la trave; (c)~diagramma del momento flettente $M(z)$, lineare crescente da $-\mu _A$ in $A$ a $\mu _B$ in $B$, con annullamento in $z^* = \mu _A\ell /(\mu _A+\mu _B)$.}}{355}{figure.caption.123}\protected@file@percent }
